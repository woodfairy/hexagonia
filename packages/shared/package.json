{
  "name": "@hexagonia/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b tsconfig.json && node ../../scripts/copy-json-assets.mjs src/scenarioCatalog.json dist/scenarioCatalog.json",
