{
  "name": "@hexagonia/rules",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "dependencies": {
    "@hexagonia/shared": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json && node ./scripts/copy-json-assets.mjs src/seafarersOfficialScenarioData.json dist/seafarersOfficialScenarioData.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "pnpm run test:unit && pnpm run test:regression",
    "test:unit": "echo \"No unit tests in rules\"",
    "test:regression": "vitest run",
    "lint": "pnpm run typecheck",
    "format": "echo \"Formatting handled at repo level\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
